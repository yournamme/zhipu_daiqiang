# Web 服务监听地址；本机使用保持 127.0.0.1，需要局域网访问时再改成 0.0.0.0。
APP_HOST=127.0.0.1

# Web 服务监听端口；start.bat 会按这个端口启动后端服务。
APP_PORT=8787

# 本地数据目录；相对路径会按项目根目录解析。
DATA_DIR=data

# BigModel API 根地址；通常不需要修改。
BIGMODEL_API_BASE=https://www.bigmodel.cn/api

# BigModel 请求头 Origin；通常不需要修改。
BIGMODEL_ORIGIN=https://www.bigmodel.cn

# BigModel 请求头 Referer；用于模拟浏览器来源。
BIGMODEL_REFERER=https://www.bigmodel.cn/glm-coding

# 全局兜底浏览器指纹 profile；账号导入后会优先使用账号级随机 profile。
BROWSER_IMPERSONATE=chrome146

# 同步账号上下文失败后的最大换指纹重试次数；小于 1 时后端会按 1 处理。
BOOTSTRAP_FINGERPRINT_MAX_RETRIES=99

# 上游 HTTP 请求超时时间，单位秒。
REQUEST_TIMEOUT_SECONDS=20

# 启动默认出口模式；仅支持 local 或 dynamic_proxy。
NETWORK_EGRESS_MODE=local

# 默认请求语言；会写入 Accept-Language 和 Set-Language。
DEFAULT_LANGUAGE=zh

# 腾讯验证码域名；通常不需要修改。
TENCENT_CAPTCHA_DOMAIN=https://turing.captcha.qcloud.com

# 腾讯验证码业务 aid；由目标站点页面使用的验证码配置决定。
TENCENT_CAPTCHA_AID=196026326

# 腾讯验证码 entry_url 和默认来源页面；通常保持 GLM Coding 页面地址。
TENCENT_CAPTCHA_ENTRY_URL=https://www.bigmodel.cn/glm-coding

# 腾讯验证码客户端预留最大重试次数；主流程重试逻辑仍由支付服务控制。
TENCENT_CAPTCHA_MAX_RETRIES=3

# OCR 点位最低置信度；低于该值会刷新验证码重新识别。
TENCENT_CAPTCHA_MIN_CONFIDENCE=0.55

# 运行腾讯 TDC VM 的 Node.js 命令；如果系统命令不是 node，请改成实际路径。
TENCENT_CAPTCHA_NODE=node

# 是否启用本地 OCR；1 表示启用，0 表示关闭自动识别。
TENCENT_OCR_ENABLED=1

# 是否在 OCR 结果中附带调试图像；开启后日志和响应体会更大。
TENCENT_OCR_INCLUDE_DEBUG=0

# OCR worker 数量；越大并发越高，内存占用也越高。
TENCENT_OCR_WORKERS=4

# 单次 OCR worker 超时时间，单位秒。
TENCENT_OCR_TIMEOUT_SECONDS=6

# 每个 OCR worker 内 OpenCV 线程数；建议保持 1，避免多进程并发时线程过多。
TENCENT_OCR_OPENCV_THREADS=1

# 每个 OCR worker 内 ONNXRuntime 线程数；建议保持 1，避免多 worker 互相抢线程。
TENCENT_OCR_ONNX_THREADS=1

# OCR worker 空闲收缩时间，单位秒；当前作为预留配置保留。
TENCENT_OCR_IDLE_SHRINK_SECONDS=60

# 运行日志级别；常用值为 DEBUG、INFO、WARNING、ERROR。
RUNTIME_LOG_LEVEL=INFO

# 运行日志保留天数。
RUNTIME_LOG_RETENTION_DAYS=7

# 动态代理模式的代理池入口；留空表示动态代理模式不可用。
FALLBACK_PROXY_URL=

# 是否只在 ticket 池 drain 阶段使用 FALLBACK_PROXY_URL；1 表示仅 ticket 池阶段使用。
FALLBACK_PROXY_TICKET_POOL_ONLY=0

# 是否启用代理服务商白名单接口；1 表示启动时尝试添加当前出口 IP。
PROXY_WHITEIP_ENABLED=0

# 代理服务商 API 身份 ID；不用白名单接口时留空。
PROXY_WHITEIP_SECRET_ID=

# 代理服务商 API 密钥；不用白名单接口时留空。
PROXY_WHITEIP_SECRET_KEY=

# 代理服务商动态令牌接口地址；仅在服务商需要先用密钥换取令牌时填写。
PROXY_WHITEIP_SECRET_TOKEN_API=

# 代理服务商签名方式；按所选代理服务商文档填写，默认保留 token。
PROXY_WHITEIP_SIGN_TYPE=token

# 代理服务商签名令牌；如果使用密钥自动换取令牌，可留空。
PROXY_WHITEIP_SIGNATURE=

# 代理服务商白名单接口地址；按自己的代理池服务商文档填写，模板不预设外部网站。
PROXY_WHITEIP_API=

# 需要加入白名单的 IP 列表；留空时由代理服务商接口自行识别当前出口 IP。
PROXY_WHITEIP_LIST=

# 调用白名单接口后等待代理池生效的时间，单位秒。
PROXY_WHITEIP_WAIT_SECONDS=5

# 代理健康检测后的最大允许延迟，单位毫秒；超过该值的代理会被丢弃。
PROXY_POOL_MAX_LATENCY_MS=3000

# 运行时只在延迟排序最靠前的 N 个代理内轮询；小于 1 时不限制窗口。
PROXY_POOL_FAST_WINDOW=32

# 某个代理连接失败后的冷却时间，单位秒；冷却期内不再分配请求给该代理。
PROXY_POOL_FAILURE_COOLDOWN_SECONDS=60
